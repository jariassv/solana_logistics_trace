# Copy to `.env` and adjust per cluster. Do not commit real secrets.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL (values match infra/docker-compose.yml by default)
# Start DB: docker compose -f infra/docker-compose.yml up -d
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://logistics_user:logistics_pass@localhost:5432/logistics_trace

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Solana / Anchor — default: localnet
# -----------------------------------------------------------------------------
# Allowed: localnet | devnet | testnet | mainnet-beta
SOLANA_NETWORK=localnet
SOLANA_RPC_URL=http://127.0.0.1:8899
SOLANA_WS_URL=ws://127.0.0.1:8900
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899
PROGRAM_ID=ReplaceWithProgramIdAfterDeploy

# devnet example (swap RPC and network together; keep PROGRAM_ID in sync):
# SOLANA_NETWORK=devnet
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WS_URL=wss://api.devnet.solana.com
# ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# testnet example:
# SOLANA_NETWORK=testnet
# SOLANA_RPC_URL=https://api.testnet.solana.com
# SOLANA_WS_URL=wss://api.testnet.solana.com
# ANCHOR_PROVIDER_URL=https://api.testnet.solana.com

# -----------------------------------------------------------------------------
# Frontend (public; exposed to the browser — no secrets)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SOLANA_NETWORK=localnet
NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899
NEXT_PUBLIC_PROGRAM_ID=ReplaceWithProgramIdAfterDeploy
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
